{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://onlygrins.example/schema/games-manifest.schema.json",
  "title": "OnlyGrins game.json manifest",
  "description": "Per-game manifest that drives `php artisan games:sync`. One file per games/<slug>/ folder.",
  "type": "object",
  "additionalProperties": false,
  "required": ["slug", "title", "category", "short_description", "game_type", "entry", "import_id"],
  "properties": {
    "$schema": { "type": "string" },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Kebab-case identity. MUST equal the folder name."
    },
    "title": { "type": "string", "minLength": 1 },
    "category": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Category slug; games:sync resolves/creates the category_id."
    },
    "short_description": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "game_type": { "const": "html5" },
    "entry": {
      "type": "string",
      "default": "index.html",
      "description": "Entry HTML file, relative to the game folder."
    },
    "width": { "type": "integer", "minimum": 1, "default": 800 },
    "height": { "type": "integer", "minimum": 1, "default": 600 },
    "controls": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "thumbnail": {
      "type": "string",
      "description": "Optional path to 16:9 catalog art within the game folder (e.g. thumbnail.png)."
    },
    "is_mobile_compatible": { "type": "boolean", "default": false },
    "api_enabled": { "type": "boolean", "default": true },
    "is_active": { "type": "boolean", "default": true },
    "is_featured": { "type": "boolean", "default": false },
    "import_id": {
      "type": "string",
      "pattern": "^edu:[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Stable external id owned by this pipeline. MUST start with 'edu:'."
    }
  }
}
